# 🔧 Blogging Service Environment Configuration

# MongoDB Configuration
MONGO_URI=mongodb://mongo:27017
MONGO_DB=blog_db
MONGO_COLLECTION=blogs
MONGO_USERNAME=admin
MONGO_PASSWORD=password123

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_THREADS=4

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/blogging-app.log

# Pagination Defaults
DEFAULT_PAGE=1
DEFAULT_LIMIT=10
MAX_LIMIT=100

# Feature Flags
ENABLE_CORS=true
ENABLE_HEALTH_CHECK=true
ENABLE_STATS=true

# Security (for future use)
JWT_SECRET=your-secret-key-here
API_KEY_REQUIRED=false

# Email Notifications (for future use)
ENABLE_EMAIL=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# CDN Settings (for future use)
CDN_ENABLED=false
CDN_URL=https://cdn.example.com

# Performance
DB_CONNECTION_POOL_SIZE=10
REQUEST_TIMEOUT=30000

# Environment
ENVIRONMENT=development
